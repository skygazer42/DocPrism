# Router-only node aggregating local GPUs and remote MinerU FastAPI workers.

MINERU_VLM_GPUS=none
MINERU_VLM_ROUTER_HOST=0.0.0.0
MINERU_VLM_ROUTER_PORT=18100

# Space-separated upstream FastAPI worker base URLs. Each must expose MinerU
# FastAPI endpoints such as /health and /file_parse.
MINERU_VLM_UPSTREAM_URLS="http://10.168.2.111:18101 http://10.168.2.112:18101"

MINERU_VLM_LAB_PORT=18180
MINERU_VLM_BASE_URL=http://127.0.0.1:18100
MAX_CONCURRENT_VLM_PAGES=16

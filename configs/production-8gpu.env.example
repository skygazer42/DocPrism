# Copy to /data/mineru-vlm-lab/production.env and adjust per node.

MINERU_VLM_GPUS=0,1,2,3,4,5,6,7
MINERU_VLM_ROUTER_HOST=127.0.0.1
MINERU_VLM_ROUTER_PORT=18100
MINERU_VLM_WORKER_HOST=127.0.0.1
MINERU_VLM_PRELOAD=true
# Keep per-worker VLM concurrency conservative. On RTX 4090, 6 concurrent
# crop parses per worker increased tail latency in live tests.
MINERU_VLM_WORKER_CONCURRENCY=3
MINERU_PROCESSING_WINDOW_SIZE=128

# vLLM VLM path. MinerU passes official vLLM arguments through mineru-router.
MINERU_VLLM_GPU_MEMORY_UTILIZATION=0.90
MINERU_VLLM_MAX_MODEL_LEN=8192
# Optional explicit KV cache budget per GPU. Leave empty unless profiling shows
# a better fixed value than gpu-memory-utilization inference.
MINERU_VLLM_KV_CACHE_MEMORY_BYTES=

MINERU_VLM_LAB_PORT=18180
MINERU_VLM_BASE_URL=http://127.0.0.1:18100
MAX_CONCURRENT_VLM_PAGES=24
FAST_TEXT_CHUNK_CHARS=5000
NATIVE_TABLE_EXTRACTION_MODE=defer
DEFERRED_TABLE_QUEUE_MODE=complex

# Keep embedding off VLM GPUs. For production, point this at a separate
# embedding service or CPU/GPU pool so MinerU VLM cards stay hot.
EMBEDDING_PROVIDER=transformers
EMBEDDING_MODEL_PATH=/data/mineru-vlm-lab/.cache/modelscope/BAAI/bge-small-zh-v1___5
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_DIM=0
EMBEDDING_MAX_LENGTH=512
EMBEDDING_BATCH_SIZE=128
MAX_CONCURRENT_EMBEDDING_BATCHES=1
PRELOAD_EMBEDDING=false

# Enhancement routing. Captioned figures keep image assets and native PDF
# captions; noisy native tables and uncaptioned complex figures still use VLM.
ENHANCEMENT_IMAGE_VLM_MODE=complex_uncaptioned
ENHANCEMENT_CROP_PADDING=8
ENHANCEMENT_CROP_SCALE=2
ENHANCEMENT_TABLE_CROP_PADDING=40
ENHANCEMENT_TABLE_CROP_SCALE=4

# Scanned/image-only pages. In auto mode the parser uses tesseract TSV OCR when
# the binary is available, keeps a page image asset, and sends only table-like
# OCR regions to VLM. Without a local OCR engine it falls back to page-level VLM.
SCAN_OCR_MODE=auto
SCAN_OCR_TESSERACT_BIN=/data/mineru-vlm-lab/.conda/ocr/bin/tesseract
SCAN_OCR_LANG=eng
SCAN_OCR_RENDER_SCALE=2
SCAN_OCR_MIN_TEXT_CHARS=80
SCAN_OCR_TABLE_MAX_LINE_GAP=30
SCAN_OCR_TIMEOUT_SECONDS=30

ENHANCEMENT_CLAIM_LIMIT=24
ENHANCEMENT_CONCURRENCY=24
ENHANCEMENT_LEASE_TIMEOUT_SECONDS=300
ENHANCEMENT_VLM_TIMEOUT_SECONDS=120
ENHANCEMENT_TIMEOUT_CLEANUP_COMMAND=/data/mineru-vlm-lab/scripts/recycle_vlm_router.sh
ENHANCEMENT_TIMEOUT_CLEANUP_COOLDOWN_SECONDS=90
ENHANCEMENT_TIMEOUT_CLEANUP_COMMAND_TIMEOUT_SECONDS=180
ENHANCEMENT_INTERVAL_SECONDS=1
ENHANCEMENT_WORKER_ID=table-vlm-worker-1

# Direct VLM workers for page/block enhancement pools. This profile favors one
# hot vLLM worker per GPU with high KV/cache residency; add more replicas only
# after profiling shows spare VRAM and no tail-latency regression.
DIRECT_VLM_GPUS=0,1,2,3,4,5,6,7
DIRECT_VLM_REPLICAS_PER_GPU=1
DIRECT_VLM_CLAIM_LIMIT=2
DIRECT_VLM_REPLICA_GPU_MEMORY_UTILIZATION=0.90
DIRECT_VLM_MAX_MODEL_LEN=8192
DIRECT_VLM_MAX_IMAGE_WIDTH=512
DIRECT_VLM_MAX_TABLE_IMAGE_WIDTH=640
DIRECT_VLM_MAX_PAGE_IMAGE_WIDTH=1024
DIRECT_VLM_INTERVAL_SECONDS=0.1

# Orchestrator emits per-task max_image_width for adaptive table crops. Keep
# the worker default at 640 and let only complex/noisy tables request 768.
ENHANCEMENT_TABLE_MAX_IMAGE_WIDTH=640
ENHANCEMENT_COMPLEX_TABLE_MAX_IMAGE_WIDTH=768
ENHANCEMENT_COMPLEX_TABLE_MIN_ROWS=8
ENHANCEMENT_COMPLEX_TABLE_MIN_COLUMNS=6
ENHANCEMENT_COMPLEX_TABLE_MIN_CHARS=900
ENHANCEMENT_COMPLEX_TABLE_MIN_LINES=10
ENHANCEMENT_COMPLEX_TABLE_MIN_AREA=0
DEFERRED_TABLE_MIN_COMPLEX_BLOCKS=5
DEFERRED_TABLE_MIN_COMPLEX_CHARS=700
